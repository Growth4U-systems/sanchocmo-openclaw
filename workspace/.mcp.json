{
  "mcpServers": {
    "notion": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.notion.com/mcp"]
    },
    "google_workspace": {
      "command": "uvx",
      "args": ["workspace-mcp", "--single-user"],
      "env": {
        "GOOGLE_OAUTH_CLIENT_ID": "YOUR_CLIENT_ID.apps.googleusercontent.com",
        "GOOGLE_OAUTH_CLIENT_SECRET": "GOCSPX-YOUR_SECRET_HERE",
        "USER_GOOGLE_EMAIL": "your@email.com",
        "OAUTHLIB_INSECURE_TRANSPORT": "1"
      }
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp", "--browser", "chrome"]
    },
    "nanobanana": {
      "command": "npx",
      "args": ["-y", "@aeven/nanobanana-mcp"],
      "env": {
        "MODEL_API_KEY": "${OPENROUTER_API_KEY}"
      }
    }
  }
}
