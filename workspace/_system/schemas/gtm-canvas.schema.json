{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sanchocmo.com/schemas/gtm-canvas.schema.json",
  "title": "GTM Canvas",
  "description": "Complete GTM Canvas state (Maja Voje framework)",
  "type": "object",
  "required": ["stage", "market", "customer", "product", "pricing", "positioning", "growth"],
  "properties": {
    "stage": {
      "type": "string",
      "enum": ["Problem-Solution Fit", "Product-Market Fit", "GTM Fit", "Scaling"],
      "description": "Current GTM stage"
    },
    "market": {
      "type": "object",
      "description": "From market-intelligence skill",
      "properties": {
        "sector": {"type": "string"},
        "tam_sam_som": {
          "type": "object",
          "properties": {
            "tam": {"type": "string"},
            "sam": {"type": "string"},
            "som": {"type": "string"}
          }
        },
        "growth_rate": {"type": "string"},
        "characteristics": {"type": "array", "items": {"type": "string"}},
        "trends": {"type": "array", "items": {"type": "string"}}
      }
    },
    "customer": {
      "type": "object",
      "description": "From icp.md and ecps.md",
      "properties": {
        "icp_segments": {"type": "array", "items": {"$ref": "icp.schema.json"}},
        "ecps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {"type": "string"},
              "problem": {"type": "string"},
              "reachability_score": {"type": "integer", "minimum": 1, "maximum": 10}
            }
          }
        }
      }
    },
    "product": {
      "type": "object",
      "description": "From company-context and product-analysis",
      "properties": {
        "description": {"type": "string"},
        "key_features": {"type": "array", "items": {"type": "string"}},
        "differentiation": {"type": "string"}
      }
    },
    "pricing": {
      "type": "object",
      "description": "From pricing.md (future)",
      "properties": {
        "model": {"type": "string"},
        "tiers": {"type": "array", "items": {"type": "object"}},
        "value_metric": {"type": "string"}
      }
    },
    "positioning": {
      "type": "object",
      "description": "From positioning.md",
      "properties": {
        "primary_angle": {"type": "string"},
        "proof_points": {"type": "array", "items": {"type": "string"}}
      }
    },
    "growth": {
      "type": "object",
      "description": "GTM motions (from Phase 2/3)",
      "properties": {
        "motions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["PLG", "Inbound", "Outbound", "Paid", "Community", "Partners", "ABM"]
          }
        },
        "active_loops": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["Usage", "Collaboration", "UGC", "Referral", "Network Effects"]
          }
        }
      }
    },
    "last_updated": {
      "type": "string",
      "format": "date"
    }
  }
}
