{
  "name": "mission-control",
  "version": "0.14.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:plugins": "node --test plugins/mc-chat/src/__tests__/*.test.js",
    "test:lib": "tsx --test src/lib/__tests__/*.test.mts src/lib/data/__tests__/*.test.mts src/lib/metrics/__tests__/*.test.mts src/lib/calc-creator-core/__tests__/*.test.mts src/lib/partnerships/__tests__/*.test.mts",
    "test:calc": "tsx --test src/lib/calc-creator-core/__tests__/*.test.mts",
    "test:partnerships": "tsx --test src/lib/partnerships/__tests__/*.test.mts",
    "test:metrics": "tsx --tsconfig tsconfig.tsx-tests.json --test src/components/dashboard/metrics-v2/__tests__/*.test.tsx",
    "migrate:media": "tsx scripts/migrate-legacy-media.mts",
    "check:drafts": "tsx scripts/check-legacy-media.mts",
    "audit:docs": "tsx scripts/audit-doc-paths.mts --check",
    "fix:docs": "tsx scripts/audit-doc-paths.mts --fix",
    "test:doc-paths": "tsx scripts/test-doc-paths.mts",
    "lint:paths": "tsx scripts/lint-paths.mts",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:local": "node scripts/migrate-local.mjs",
    "db:generate:local": "drizzle-kit generate --config drizzle.local.config.ts",
    "db:migrate:mcp": "node scripts/apply-sql-migration.mjs src/db/migrations/0006_mcp_audit_events.sql",
    "db:migrate:deploy": "node scripts/apply-sql-migration.mjs src/db/migrations/0006_mcp_audit_events.sql src/db/migrations/0007_feedback_insights.sql src/db/migrations/0008_comments_v2.sql src/db/migrations/0011_metric_snapshots.sql src/db/migrations/0012_metric_dashboards.sql src/db/migrations/0013_intelligence_engine.sql src/db/migrations/0014_metric_schedule_runs.sql src/db/migrations/0015_metric_semantic_layer.sql",
    "db:verify": "tsx scripts/verify-migration.ts",
    "backfill:metrics": "tsx scripts/metrics/backfill-metric-snapshots.ts",
    "seed:paid-ads": "tsx scripts/metrics/seed-paid-ads.ts",
    "seed:product": "tsx scripts/metrics/seed-product.ts",
    "seed:web-seo": "tsx scripts/metrics/seed-web-seo.ts",
    "export:metrics": "node scripts/metrics/export-metric-snapshots.mjs",
    "compute:metric-kpis": "tsx scripts/metrics/compute-kpis.ts",
    "db:sync-tasks": "tsx scripts/migrate-projects-to-db.ts --apply",
    "db:sync-tasks:dry": "tsx scripts/migrate-projects-to-db.ts --dry-run",
    "collect:ingest": "tsx scripts/ingest-metrics.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1027.0",
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@neondatabase/serverless": "^1.0.2",
    "@polar-sh/sdk": "^0.47.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.96.1",
    "@toast-ui/editor": "^3.2.2",
    "archiver": "^7.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "formidable": "^3.5.4",
    "lucide-react": "^1.7.0",
    "next": "14.2.35",
    "next-auth": "^4.24.13",
    "next-intl": "^4.9.0",
    "postgres": "^3.4.5",
    "react": "^18",
    "react-dom": "^18",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "tsx": "^4.21.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@playwright/test": "^1.59.1",
    "@types/archiver": "^7.0.0",
    "@types/formidable": "^3.5.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "husky": "^9.1.7",
    "playwright": "^1.59.1",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
