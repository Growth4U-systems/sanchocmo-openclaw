{
  "name": "mission-control",
  "version": "1.9.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:plugins": "node --check plugins/mc-chat/src/index.js && node --test plugins/mc-chat/src/__tests__/*.test.js",
    "test:lib": "tsx --test src/lib/__tests__/*.test.mts src/lib/data/__tests__/*.test.mts src/lib/metrics/__tests__/*.test.mts src/lib/calc-creator-core/__tests__/*.test.mts src/lib/partnerships/__tests__/*.test.mts src/lib/chat/__tests__/*.test.mts src/lib/runtime/__tests__/*.test.mts src/lib/leads/__tests__/*.test.mts",
    "test:calc": "tsx --test src/lib/calc-creator-core/__tests__/*.test.mts",
    "test:partnerships": "tsx --test src/lib/partnerships/__tests__/*.test.mts",
    "test:partnerships-ui": "tsx --tsconfig tsconfig.tsx-tests.json --test src/components/partnerships/__tests__/*.test.tsx",
    "test:metrics": "tsx --tsconfig tsconfig.tsx-tests.json --test src/components/dashboard/metrics-v2/__tests__/*.test.tsx",
    "test:runtime": "tsx --test src/lib/__tests__/runtime-*.test.mts && node --test docker/runtimes/*/bridge.test.mjs",
    "smoke:runtime:external-http": "node scripts/smoke-external-http.mjs",
    "smoke:runtime:external-http:bridge": "node scripts/smoke-external-http.mjs --protocol=mc-bridge",
    "smoke:runtime:codex": "node scripts/smoke-cli-runtime.mjs --runtime=codex",
    "smoke:execution-control": "tsx scripts/smoke-execution-control.mts",
    "smoke:execution-control:upgrade": "tsx scripts/smoke-execution-control-upgrade.mts",
    "execution:origin-cutover:check": "tsx scripts/verify-execution-origin-cutover.mts",
    "execution:projection:repair": "tsx scripts/repair-terminal-projection.mts",
    "staging:canary:preflight": "tsx scripts/preflight-staging-canary.mts",
    "partnerships:cancellation:drain": "tsx scripts/drain-partnerships-cancellation.mts",
    "smoke:runtime:claude-code": "node scripts/smoke-cli-runtime.mjs --runtime=claude-code",
    "deploy:prod": "node scripts/deploy-prod.mjs",
    "migrate:media": "tsx scripts/migrate-legacy-media.mts",
    "check:drafts": "tsx scripts/check-legacy-media.mts",
    "check:product-capabilities": "tsx scripts/check-product-capabilities.mts --strict",
    "audit:docs": "tsx scripts/audit-doc-paths.mts --check",
    "fix:docs": "tsx scripts/audit-doc-paths.mts --fix",
    "test:doc-paths": "tsx scripts/test-doc-paths.mts",
    "lint:paths": "tsx scripts/lint-paths.mts",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:local": "node scripts/migrate-local.mjs",
    "db:generate:local": "drizzle-kit generate --config drizzle.local.config.ts",
    "db:migrate:mcp": "node scripts/apply-sql-migration.mjs src/db/migrations/0006_mcp_audit_events.sql",
    "db:migrate:agent-runs": "node scripts/apply-sql-migration.mjs src/db/migrations/0018_agent_runs.sql",
    "db:migrate:agent-runs:check": "node scripts/apply-sql-migration.mjs --dry-run src/db/migrations/0018_agent_runs.sql",
    "db:migrate:execution-control": "node scripts/run-execution-control-migrations.mjs",
    "db:migrate:execution-control:check": "node scripts/run-execution-control-migrations.mjs --dry-run",
    "db:migrate:execution-control:adopt": "node scripts/run-execution-control-migrations.mjs --adopt",
    "db:migrate:deploy": "node scripts/apply-sql-migration.mjs src/db/migrations/0006_mcp_audit_events.sql src/db/migrations/0007_feedback_insights.sql src/db/migrations/0008_comments_v2.sql src/db/migrations/0011_metric_snapshots.sql src/db/migrations/0012_metric_dashboards.sql src/db/migrations/0013_intelligence_engine.sql src/db/migrations/0014_metric_schedule_runs.sql src/db/migrations/0015_metric_semantic_layer.sql src/db/migrations/0016_metric_stage_rollups.sql src/db/migrations/0017_task_route_proposals.sql src/db/migrations/0034_metric_source_run_date_basis.sql",
    "db:verify": "tsx scripts/verify-migration.ts",
    "backfill:metrics": "tsx scripts/metrics/backfill-metric-snapshots.ts",
    "seed:paid-ads": "tsx scripts/metrics/seed-paid-ads.ts",
    "seed:product": "tsx scripts/metrics/seed-product.ts",
    "seed:web-seo": "tsx scripts/metrics/seed-web-seo.ts",
    "collect:lemlist": "tsx scripts/metrics/collect-lemlist.ts",
    "export:metrics": "node scripts/metrics/export-metric-snapshots.mjs",
    "compute:metric-kpis": "tsx scripts/metrics/compute-kpis.ts",
    "db:sync-tasks": "tsx scripts/migrate-projects-to-db.ts --apply",
    "db:sync-tasks:dry": "tsx scripts/migrate-projects-to-db.ts --dry-run",
    "collect:ingest": "tsx scripts/ingest-metrics.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1086.0",
    "@base-ui/react": "^1.6.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@neondatabase/serverless": "^1.1.0",
    "@polar-sh/sdk": "^0.48.1",
    "@swc/helpers": "0.5.23",
    "@tailwindcss/typography": "^0.5.20",
    "@tanstack/react-query": "^5.101.2",
    "@toast-ui/editor": "^3.2.2",
    "archiver": "^8.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "formidable": "^3.5.4",
    "js-yaml": "^5.2.1",
    "lucide-react": "^1.24.0",
    "next": "14.2.35",
    "next-auth": "^4.24.14",
    "next-intl": "^4.13.2",
    "postgres": "^3.4.5",
    "react": "^18",
    "react-dom": "^18",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.23.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@playwright/test": "^1.61.1",
    "@types/archiver": "^8.0.0",
    "@types/formidable": "^3.5.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "15.5.20",
    "husky": "^9.1.7",
    "playwright": "^1.59.1",
    "postcss": "^8",
    "prettier": "^3.9.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^6"
  }
}
