# Cervantes — entorno del servicio systemd (cervantes-claude-code).
# Copiá a `.env` y completá valores. El servicio lo lee vía `EnvironmentFile=`.
# IMPORTANTE: aislado del .env de OpenClaw/Sancho para evitar colisiones
# (en particular DISCORD_BOT_TOKEN, que apunta a bots distintos en cada env).
# Los crons de Cervantes siguen haciendo `source` de /root/.openclaw/.env por su cuenta.

# === Claude Code ===
# OAuth token para que `claude` arranque sin pedir login. Generar con `claude setup-token`.
CLAUDE_CODE_OAUTH_TOKEN=

# === Discord Bot (Cervantes) ===
# El plugin oficial de Discord (claude-plugins-official/discord) lee
# process.env.DISCORD_BOT_TOKEN hardcoded. Acá va el token del bot de Cervantes
# (NO el de Sancho/OpenClaw, que vive en el .env de OpenClaw).
DISCORD_BOT_TOKEN=
CERVANTES_DISCORD_BOT_CLIENT_ID=
CERVANTES_GUILD_ID=

# === Alertas ===
# Webhook usado por scripts/discord-alert.sh y scripts/healthcheck.sh para
# notificar fallas en #cervantes-admin.
DISCORD_WEBHOOK_CERVANTES=

# === Paths ===
OPENCLAW_HOME=/root/.openclaw
