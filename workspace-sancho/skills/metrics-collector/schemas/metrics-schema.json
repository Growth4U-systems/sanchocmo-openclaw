{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Metrics Collection",
  "description": "Standardized daily metrics collection output",
  "type": "object",
  "required": ["slug", "collectedAt", "dateRange", "sources"],
  "properties": {
    "slug": {
      "type": "string",
      "description": "Client slug identifier"
    },
    "collectedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO timestamp of when collection ran"
    },
    "dateRange": {
      "type": "object",
      "required": ["from", "to"],
      "properties": {
        "from": { "type": "string", "format": "date" },
        "to": { "type": "string", "format": "date" }
      }
    },
    "sources": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["ok", "error", "skipped", "not_configured"]
          },
          "error": {
            "type": "string",
            "description": "Error message if status is error"
          },
          "collectedAt": {
            "type": "string",
            "format": "date-time"
          },
          "metrics": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "value"],
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Metric name (e.g. sessions, clicks, spend)"
                },
                "value": {
                  "description": "Metric value (number or string)",
                  "oneOf": [
                    { "type": "number" },
                    { "type": "string" }
                  ]
                },
                "date": {
                  "type": "string",
                  "format": "date",
                  "description": "Date this metric applies to"
                },
                "dimensions": {
                  "type": "object",
                  "additionalProperties": { "type": "string" },
                  "description": "Optional dimension breakdowns (e.g. campaign, query, page)"
                }
              }
            }
          }
        }
      }
    }
  }
}
