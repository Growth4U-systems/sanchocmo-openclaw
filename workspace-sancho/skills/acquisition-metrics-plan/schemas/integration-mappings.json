{
  "_doc": "Maps integration providers to the metrics they can supply. Used by generate-plan.js to auto-map funnel steps and KPIs to connected integrations.",

  "ga4": {
    "label": "Google Analytics 4",
    "provides": {
      "webTraffic": { "metric": "sessions", "label": "Sessions" },
      "users": { "metric": "totalUsers", "label": "Users" },
      "newUsers": { "metric": "newUsers", "label": "New Users" },
      "pageviews": { "metric": "screenPageViews", "label": "Pageviews" },
      "bounceRate": { "metric": "bounceRate", "label": "Bounce Rate", "format": "percent" },
      "engagementRate": { "metric": "engagementRate", "label": "Engagement Rate", "format": "percent" },
      "avgDuration": { "metric": "averageSessionDuration", "label": "Avg Duration", "format": "seconds" },
      "channelBreakdown": { "metric": "sessions", "dimension": "channel", "label": "Traffic by Channel" },
      "topPages": { "metric": "topPage", "dimension": "page", "label": "Top Pages" },
      "deviceBreakdown": { "metric": "sessions", "dimension": "device", "label": "By Device" },
      "visits": { "metric": "sessions", "label": "Visits" },
      "cartAbandonment": { "metric": "cartAbandonment", "label": "Cart Abandonment", "format": "percent", "optional": true }
    },
    "funnelMaps": {
      "Visits": "sessions",
      "Visits/Installs": "sessions",
      "Searches/Visits": "sessions",
      "Downloads": null,
      "Add to Cart": null,
      "Checkout Started": null,
      "Purchase": null
    }
  },

