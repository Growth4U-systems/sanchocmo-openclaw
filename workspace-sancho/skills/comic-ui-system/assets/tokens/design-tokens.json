{
  "colors": {
    "backgrounds": {
      "parchment": "#F5F0E6",
      "paper": "#FDF8EF",
      "aged": "#E8DCC8"
    },
    "ink": {
      "DEFAULT": "#1A1A2E",
      "soft": "#2D2D44"
    },
    "accents": {
      "rust": { "DEFAULT": "#C45D35", "light": "#D4734F", "dark": "#A34A28" },
      "navy": "#1E3A5F",
      "cyan": { "DEFAULT": "#3B9EBF", "light": "#5BBAD9" },
      "yellow": { "DEFAULT": "#F2C94C", "pale": "#FFF3C4" },
      "sage": "#4A5D23",
      "red": "#C0392B"
    }
  },
  "shadows": {
    "comic-xs": "3px 3px 0px 0px #1A1A2E",
    "comic-sm": "4px 4px 0px 0px #1A1A2E",
    "comic": "6px 6px 0px 0px #1A1A2E",
    "comic-lg": "8px 8px 0px 0px #1A1A2E",
    "comic-xl": "10px 10px 0px 0px #1A1A2E"
  },
  "borders": {
    "standard": "4px solid #1A1A2E",
    "heavy": "5px solid #1A1A2E",
    "thin": "2px solid #1A1A2E",
    "section": "4px solid #1A1A2E"
  },
  "typography": {
    "bangers": { "variable": "--font-bangers", "fallback": "cursive", "role": "headlines, CTAs, action text" },
    "comic-neue": { "variable": "--font-comic-neue", "fallback": "cursive", "role": "speech, body, descriptions" },
    "playfair": { "variable": "--font-playfair", "fallback": "serif", "role": "narrator captions, story" },
    "source-sans": { "variable": "--font-source-sans", "fallback": "sans-serif", "role": "metadata, small labels" }
  },
  "timing": {
    "ease-soft-out": "cubic-bezier(0.16, 1, 0.3, 1)",
    "ease-soft-spring": "cubic-bezier(0.34, 1.56, 0.64, 1)"
  },
  "hover": {
    "translate": "-3px, -3px",
    "rotation": "-0.5deg",
    "shadow-escalation": "comic → comic-lg",
    "duration": "200ms"
  }
}
