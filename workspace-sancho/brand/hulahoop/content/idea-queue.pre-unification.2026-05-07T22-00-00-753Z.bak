    "id": "idea-2026-05-06-6",
    "title": "Deducción del 54% para inversores en cine español: el incentivo que las empresas desconocen",
    "pillar_id": "incentivos-fiscales",
    "content_type": "Framework",
    "target_channel": "linkedin",
