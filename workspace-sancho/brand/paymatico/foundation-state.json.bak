  "brand_summary": {
    "company_name": "Paymático",
    "sector": "Fintech B2B — Pagos y cuentas programables",
    "description": "Entidad de pago regulada por BdE. Consolida inteligencia de pagos: tarjetas, SEPA, transferencias, TPVs. Cuentas programables tipo IFTTT. Marca blanca para franquicias.",
    "north_star": "Franquicias españolas con redes de TPVs",
    "icps": [
      "Franquicias españolas (automoción, restauración, salud)",
      "Corporates con filiales (distribuidoras, constructoras)",
      "Fiduciarios (agencias de valores, notarios, inmobiliarias)"
    ],
    "competitors": [
      "Stripe",
      "Adyen",
      "Monei",
      "Mollie",
      "Multisafepay",
      "Paycomet",
      "Paynopain",
      "Pecunpay",
      "Sipay",
      "Zettle"
    ],
    "positioning": "Las ventajas de una fintech sin ser una — panel único de pagos, cuentas programables y marca blanca, todo regulado por BdE",
    "url": "https://paymatico.com"
  },
