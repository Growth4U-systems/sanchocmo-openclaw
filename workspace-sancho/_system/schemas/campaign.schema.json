{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sanchocmo.com/schemas/campaign.schema.json",
  "title": "Campaign Brief",
  "description": "Campaign structure for ./campaigns/{name}/brief.md",
  "type": "object",
  "required": ["name", "goal", "angle", "audience_segment", "timeline", "channels", "status"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Campaign name (lowercase-kebab-case)"
    },
    "goal": {
      "type": "string",
      "description": "Measurable outcome (include number if possible)"
    },
    "angle": {
      "type": "string",
      "description": "Positioning angle used (reference ./brand/positioning.md)"
    },
    "audience_segment": {
      "type": "string",
      "description": "ICP or ECP targeted (reference ./brand/icp.md or ecps.md)"
    },
    "timeline": {
      "type": "object",
      "properties": {
        "start_date": {"type": "string", "format": "date"},
        "end_date": {"type": "string", "format": "date"}
      }
    },
    "channels": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["Contenido Orgánico", "Outreach Directo", "Partners & Afiliados", "Paid Ads"]
      },
      "description": "Core Four channels"
    },
    "status": {
      "type": "string",
      "enum": ["planning", "active", "complete", "paused"],
      "description": "Campaign status"
    },
    "voice_notes": {
      "type": "string",
      "description": "Campaign-specific voice adjustments (reference ./brand/voice-profile.md)"
    },
    "gtm_canvas_alignment": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["Market", "Customer", "Product", "Pricing", "Positioning", "Growth"]
      },
      "description": "Which GTM Canvas elements this campaign activates"
    },
    "phase": {
      "type": "integer",
      "minimum": 0,
      "maximum": 3,
      "description": "SanchoCMO phase (0=Diagnose, 1=Foundation, 2=Funnel, 3=Scale)"
    },
    "assets_created": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "asset_name": {"type": "string"},
          "type": {"type": "string"},
          "path": {"type": "string"}
        }
      }
    },
    "last_updated": {
      "type": "string",
      "format": "date"
    }
  }
}
