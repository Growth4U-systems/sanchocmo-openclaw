{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sanchocmo.com/schemas/swot.schema.json",
  "title": "SWOT + TOWS Analysis",
  "description": "SWOT analysis with TOWS cross-strategies",
  "type": "object",
  "required": ["strengths", "weaknesses", "opportunities", "threats", "tows_strategies"],
  "properties": {
    "strengths": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "strength": {"type": "string"},
          "source": {"type": "string", "description": "From self-intelligence Lens"},
          "evidence": {"type": "string"}
        }
      }
    },
    "weaknesses": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "weakness": {"type": "string"},
          "source": {"type": "string"},
          "impact": {"type": "string", "enum": ["high", "medium", "low"]}
        }
      }
    },
    "opportunities": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "opportunity": {"type": "string"},
          "source": {"type": "string", "description": "From competitor or market intelligence"},
          "potential": {"type": "string", "enum": ["high", "medium", "low"]}
        }
      }
    },
    "threats": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "threat": {"type": "string"},
          "source": {"type": "string"},
          "severity": {"type": "string", "enum": ["high", "medium", "low"]}
        }
      }
    },
    "tows_strategies": {
      "type": "object",
      "description": "Cross-strategies from TOWS matrix",
      "properties": {
        "SO_strategies": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Strengths x Opportunities (leverage strengths to capture opportunities)"
        },
        "ST_strategies": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Strengths x Threats (use strengths to defend against threats)"
        },
        "WO_strategies": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Weaknesses x Opportunities (fix weaknesses to unlock opportunities)"
        },
        "WT_strategies": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Weaknesses x Threats (minimize weaknesses to avoid threats)"
        }
      }
    },
    "last_updated": {
      "type": "string",
      "format": "date"
    }
  }
}
