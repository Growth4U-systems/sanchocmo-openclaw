{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sanchocmo.com/schemas/atalaya-config.schema.json",
  "title": "Atalaya Config",
  "description": "Per-client configuration for Atalaya. Stored at brand/{slug}/atalaya/config.json. Editable from MC UI.",
  "type": "object",
  "required": ["channels_to_monitor", "followed_profiles"],
  "properties": {
    "channels_to_monitor": {
      "type": "array",
      "description": "Default channels to scrape for all competitors. Can be overridden per competitor.",
      "items": {
        "type": "string",
        "enum": ["meta_ads", "google_ads", "blog", "linkedin", "instagram", "twitter"]
      }
    },
    "competitor_overrides": {
      "type": "object",
      "description": "Per-competitor channel overrides. Key = competitor slug.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "channels": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["meta_ads", "google_ads", "blog", "linkedin", "instagram", "twitter"]
            }
          }
        }
      }
    },
    "followed_profiles": {
      "type": "object",
      "properties": {
        "linkedin": {
          "type": "array",
          "items": { "$ref": "#/$defs/profile" }
        },
        "twitter": {
          "type": "array",
          "items": { "$ref": "#/$defs/profile" }
        },
        "instagram": {
          "type": "array",
          "items": { "$ref": "#/$defs/profile" }
        }
      }
    },
    "max_results_per_channel": {
      "type": "integer",
      "default": 30
    },
    "last_scan": {
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "trigger": { "type": "string", "enum": ["manual", "cron"] },
        "status": { "type": "string", "enum": ["complete", "partial", "error"] },
        "items_found": { "type": "integer" },
        "ideas_generated": { "type": "integer" }
      }
    }
  },
  "$defs": {
    "profile": {
      "type": "object",
      "required": ["id", "name", "url", "category", "active"],
      "properties": {
        "id": { "type": "string", "description": "UUID" },
        "name": { "type": "string" },
        "url": { "type": "string", "description": "Full URL for LinkedIn, @handle for Twitter/Instagram" },
        "category": { "type": "string", "description": "Growth, Founder, SEO, AI, Marketing, etc." },
        "active": { "type": "boolean", "default": true },
        "added_at": { "type": "string", "format": "date-time" },
        "posts_monitored": { "type": "integer", "default": 0 }
      }
    }
  }
}
