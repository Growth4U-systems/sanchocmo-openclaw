{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sanchocmo.com/schemas/icp.schema.json",
  "title": "Ideal Customer Profile",
  "description": "ICP structure from niche-discovery-100x skill",
  "type": "object",
  "required": ["segment_name", "demographics", "firmographics", "psychographics"],
  "properties": {
    "segment_name": {
      "type": "string",
      "description": "ICP segment name",
      "examples": ["Fintech B2C UK", "SaaS Mid-Market EMEA"]
    },
    "demographics": {
      "type": "object",
      "properties": {
        "age_range": {"type": "string"},
        "location": {"type": "string"},
        "income_level": {"type": "string"},
        "occupation": {"type": "string"}
      }
    },
    "firmographics": {
      "type": "object",
      "description": "For B2B",
      "properties": {
        "company_size": {"type": "string"},
        "industry": {"type": "string"},
        "revenue_range": {"type": "string"},
        "decision_maker_role": {"type": "string"}
      }
    },
    "psychographics": {
      "type": "object",
      "properties": {
        "pain_points": {
          "type": "array",
          "items": {"type": "string"}
        },
        "goals": {
          "type": "array",
          "items": {"type": "string"}
        },
        "values": {
          "type": "array",
          "items": {"type": "string"}
        },
        "language": {
          "type": "string",
          "description": "How they describe their problem"
        }
      }
    },
    "reachability_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "description": "How easy to reach this segment"
    },
    "pain_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "description": "How intense their pain is"
    },
    "market_size_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "description": "Size of this segment"
    },
    "last_updated": {
      "type": "string",
      "format": "date"
    }
  }
}
