#!/usr/bin/env bash
# ============================================================================
# sancho — CLI único de ciclo de vida de SanchoCMO.
# ----------------------------------------------------------------------------
# Un solo comando para instalar, levantar, bajar, actualizar y operar el stack,
# sin que el usuario tenga que recordar los `-f docker-compose.*.yml`.
#
#   ./sancho run            arranque súper simple: si falta .env corre el wizard
#                           en modo quick y levanta; si ya está, equivale a `up`.
#                           Abre el navegador en la URL de acceso.
#   ./sancho install [--od|--yalc|--build|--no-up|--force|--quick|--advanced]
#                           primer arranque: wizard (si falta .env) + up
#   ./sancho up             levanta el stack (overlays habilitados en .env)
#   ./sancho down           baja contenedores + red, CONSERVA los datos
#   ./sancho restart        down + up
#   ./sancho update [tag]   sin arg: última del tag actual; con arg (vX.Y.Z|
#                           edge|latest): pinea SANCHOCMO_IMAGE y actualiza
#   ./sancho logs [svc]     tail -f de logs (default: sanchocmo)
#   ./sancho status         estado de los contenedores del stack
#   ./sancho destroy        down -v — BORRA los datos (pide confirmación)
#   ./sancho reconfigure    re-corre el wizard de configuración
#   ./sancho link [--force] deja `sancho` en el PATH (lo hace install solo)
#   ./sancho help           esta ayuda
# ============================================================================
set -euo pipefail

# Resolvé la cadena de symlinks hasta el archivo real ANTES de calcular
# SCRIPT_DIR: si se invoca vía el symlink global (`sancho`, ver `link`),
# BASH_SOURCE[0] es el symlink, y su dirname (p.ej. ~/.local/bin) no tiene los
# docker-compose*.yml ni el .env. A mano en vez de `readlink -f`, que no es
# portable a macOS.
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  link_dir="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  case "$SOURCE" in /*) ;; *) SOURCE="$link_dir/$SOURCE" ;; esac
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
REAL_SCRIPT="$SCRIPT_DIR/$(basename "$SOURCE")"
cd "$SCRIPT_DIR"
# shellcheck source=scripts/compose-env.sh
source "$SCRIPT_DIR/scripts/compose-env.sh"

IMAGE_REPO="ghcr.io/growth4u-systems/sanchocmo"

usage() {
  cat <<'EOF'
sancho — CLI único de ciclo de vida de SanchoCMO.

  ./sancho run            arranque súper simple: wizard quick (si falta .env) + up
                          + abre el navegador. Si ya está configurado, = `up`.
  ./sancho install [--od|--yalc|--build|--no-up|--force|--quick|--advanced]
                          primer arranque: wizard (si falta .env) + up
  ./sancho up             levanta el stack (overlays habilitados en .env)
  ./sancho down           baja contenedores + red, CONSERVA los datos
  ./sancho restart        down + up
  ./sancho update [tag]   sin arg: última del tag actual; con arg (vX.Y.Z|
                          edge|latest): pinea SANCHOCMO_IMAGE y actualiza
  ./sancho logs [svc]     tail -f de logs (default: sanchocmo)
  ./sancho status         estado de los contenedores del stack
  ./sancho destroy        down -v — BORRA los datos (pide confirmación)
  ./sancho reconfigure    re-corre el wizard de configuración
  ./sancho link [--force] deja `sancho` en el PATH (para no usar ./sancho)
  ./sancho help           esta ayuda
EOF
}

require_env() {
  [ -f .env ] || die "No hay .env todavía. Configurá primero con:  ./sancho install"
}

# Espera a que MC esté realmente listo (healthcheck del contenedor) y recién ahí
# imprime la URL de acceso — en vez de anunciar apenas `up -d` retorna, cuando
# los contenedores todavía están arrancando.
# Reprint the admin access token as the LAST thing on screen. The wizard prints
# it once, but the (often multi-minute) pull + boot output that follows buries it
# in the scrollback — so a quick install appears to finish without handing you a
# way in. Reads MC_ADMIN_TOKEN from .env; no-op if unset. (SAN-434)
print_login_hint() {
  local tok google
  tok="$(_env_get MC_ADMIN_TOKEN)"
  [ -n "$tok" ] || return 0
  google="$(_env_get GOOGLE_CLIENT_ID)"
  echo ""
  if [ -n "$google" ]; then
    echo  "   Log in with Google, or paste this admin access token on the sign-in page:"
  else
    printf '   \033[2mPaste this in the "Access Token" field on the sign-in page:\033[0m\n'
  fi
  printf '   \033[1m%s\033[0m\n' "$tok"
}

announce_ready() {
  # First boot (image seed + plugins + DB migrate + gateway) can take several
  # minutes, so wait generously (SANCHO_READY_TIMEOUT, default 600s) with live
  # progress rather than declaring "still starting" prematurely. (SAN-408)
  local base rc=0 timeout="${SANCHO_READY_TIMEOUT:-600}"
  base="$(get_base_url)"
  echo ""
  wait_until_healthy sanchocmo "$timeout" || rc=$?
  case "$rc" in
    0) bold "✅ Mission Control está arriba — entrá acá:"
       printf '   \033[1;36m%s\033[0m\n' "$base" ;;
    2) bold "Mission Control levantado:"
       echo  "   $base" ;;
    3) # Still booting past the timeout — not an error; first boot is slow.
       bold "⏳ Mission Control sigue arrancando — el primer arranque puede tardar varios minutos."
       echo  "   Esto NO es un error. Seguí el progreso:  ./sancho logs"
       echo  "   Cuando esté listo, entrá acá:            $base" ;;
    *) # Container missing/crashed — this one IS worth looking at.
       bold "⚠ El contenedor no está corriendo o no respondió."
       echo  "   Revisá qué pasó:  ./sancho logs"
       echo  "   URL prevista:     $base" ;;
  esac
  # Surface the login token last, whenever MC is up or still coming up.
  case "$rc" in 0|2|3) print_login_hint ;; esac
}

# open_browser — best-effort: abre la URL de acceso en el navegador. Silencioso
# en headless (sin xdg-open/open o sin entorno gráfico). Nunca bloquea ni falla.
open_browser() {
  local url; url="$(get_base_url)"
  if command -v xdg-open >/dev/null 2>&1; then
    xdg-open "$url" >/dev/null 2>&1 &
  elif command -v open >/dev/null 2>&1; then
    open "$url" >/dev/null 2>&1 &
  fi
  return 0
}

# ---------------------------------------------------------------------------
# link — deja `sancho` disponible en el PATH, para no depender de `./sancho`
# desde el dir del install. Nunca usa sudo: si /usr/local/bin no es escribible
# como el usuario actual, cae a ~/.local/bin.
# ---------------------------------------------------------------------------
link_global() {
  local force=0 target dir rc_file shell_name
  [ "${1:-}" = "--force" ] && force=1

  # SANCHO_LINK_DIR permite fijar el destino (útil en tests y en setups raros).
  if [ -n "${SANCHO_LINK_DIR:-}" ]; then
    dir="$SANCHO_LINK_DIR"
  elif [ -d /usr/local/bin ] && [ -w /usr/local/bin ]; then
    dir="/usr/local/bin"
  else
    dir="$HOME/.local/bin"
  fi
  mkdir -p "$dir" || { echo "  ⚠ No pude crear $dir — salteo el link global."; return 1; }
  target="$dir/sancho"

  # No pisar algo que no sea nuestro symlink, salvo --force explícito.
  if [ -e "$target" ] || [ -L "$target" ]; then
    if [ ! -L "$target" ] || [ "$(readlink "$target")" != "$REAL_SCRIPT" ]; then
      if [ "$force" != "1" ]; then
        echo "  ⚠ Ya existe $target y no es un link a este install — lo salteo."
        echo "    Si querés pisarlo:  ./sancho link --force"
        return 1
      fi
    fi
  fi

  ln -sfn "$REAL_SCRIPT" "$target" || { echo "  ⚠ No pude crear el symlink en $target."; return 1; }
  echo "  ✅ sancho global: $target → $REAL_SCRIPT"

  # Aviso de PATH (no editamos ningún rc automáticamente).
  case ":$PATH:" in
    *":$dir:"*) ;;
    *)
      shell_name="$(basename "${SHELL:-bash}")"
      case "$shell_name" in
        zsh) rc_file="~/.zshrc" ;;
        *)   rc_file="~/.bashrc" ;;
      esac
      echo "  ⚠ $dir no está en tu PATH. Agregalo a $rc_file:"
      printf '       export PATH="%s:$PATH"\n' "$dir"
      echo "    (después: abrí otra terminal o corré  source $rc_file)"
      ;;
  esac
  return 0
}

cmd_link() { link_global "$@"; }

# ---------------------------------------------------------------------------
# install — wizard (si falta .env) + up. Reemplaza al viejo install.sh.
# ---------------------------------------------------------------------------
cmd_install() {
  WITH_OD=0; WITH_YALC=0; DO_UP=1; FORCE_ARG=""; BUILD=0
  for arg in "$@"; do
    case "$arg" in
      --od) WITH_OD=1 ;;
      --yalc) WITH_YALC=1 ;;
      --no-up) DO_UP=0 ;;
      --build) BUILD=1 ;;
      --force) FORCE_ARG="--force" ;;
      # Elegir el modo del wizard (quick|advanced) sin invocarlo a mano. Se
      # exporta para que el hijo `scripts/wizard.sh` lo herede.
      --quick) export WIZARD_MODE=quick ;;
      --advanced|--full) export WIZARD_MODE=advanced ;;
      -h|--help) usage; exit 0 ;;
      *) die "Flag desconocido para install: $arg" ;;
    esac
  done

  bold "SanchoCMO — instalación"
  check_prereqs

  # Configurar (wizard) si falta .env o se fuerza.
  if [ ! -f .env ] || [ -n "$FORCE_ARG" ]; then
    echo ""
    bash scripts/wizard.sh $FORCE_ARG
  else
    echo "  ✓ .env ya presente — salteo el wizard (usá --force para reconfigurar)"
  fi

  # El contenedor lee config desde OPENCLAW_HOME (default ~/.openclaw). En un
  # install de producto/clone nadie lo setea, así que lo fijamos a este dir sin
  # pisar un valor existente (el deploy de G4U lo define). Ver SAN-138.
  ensure_env_default OPENCLAW_HOME "$SCRIPT_DIR"
  ensure_env_default SNAPSHOT_DATA_DIR "$SCRIPT_DIR/snapshots"

  detect_compose
  build_compose_args
  # Reasigná puertos de host ocupados antes de levantar (nunca fallar con
  # "port is already allocated"). Después de build_compose_args para saber si
  # el overlay OD está activo (y chequear su 7456).
  resolve_host_ports

  if [ "$DO_UP" != "1" ]; then
    echo ""
    bold "Configurado. Levantalo cuando quieras:"
    echo "  ./sancho up"
    return 0
  fi

  echo ""
  if [ "$BUILD" = "1" ]; then
    [ -f "$SCRIPT_DIR/Dockerfile" ] || die "--build necesita el source (Dockerfile) en $SCRIPT_DIR. En un install de producto (sin clonar) usá el modo normal."
    bold "Buildeando y levantando ($COMPOSE $COMPOSE_ARGS up -d --build)"
    # shellcheck disable=SC2086
    $COMPOSE $COMPOSE_ARGS up -d --build
  else
    bold "Bajando imágenes ($COMPOSE $COMPOSE_ARGS pull)"
    pull_images
    bold "Levantando contenedores ($COMPOSE $COMPOSE_ARGS up -d)"
    # shellcheck disable=SC2086
    $COMPOSE $COMPOSE_ARGS up -d
  fi
  announce_ready
  # Conveniencia, nunca fatal: si el link falla, el install igual está OK.
  echo ""
  bold "▸ sancho global"
  link_global || true
  echo ""
  echo "  Otros comandos:  sancho logs · status · update · down"
}

# ---------------------------------------------------------------------------
# up — levanta el stack con los overlays habilitados.
# ---------------------------------------------------------------------------
cmd_up() {
  require_env; detect_compose; build_compose_args; resolve_host_ports
  bold "Levantando ($COMPOSE $COMPOSE_ARGS up -d)"
  # shellcheck disable=SC2086
  $COMPOSE $COMPOSE_ARGS up -d
  announce_ready
}

# ---------------------------------------------------------------------------
# down — baja contenedores + red (todos los overlays). Conserva los datos.
# ---------------------------------------------------------------------------
cmd_down() {
  require_env; detect_compose; build_compose_args
  bold "Bajando ($COMPOSE $COMPOSE_ARGS down --remove-orphans)"
  # shellcheck disable=SC2086
  $COMPOSE $COMPOSE_ARGS down --remove-orphans
  echo "  ✓ Stack bajado. Los datos (volúmenes) se conservan — ./sancho up para volver."
}

cmd_restart() { cmd_down; echo ""; cmd_up; }

# ---------------------------------------------------------------------------
# update [tag] — pinea la versión (opcional) y baja la última imagen.
# ---------------------------------------------------------------------------
cmd_update() {
  require_env; detect_compose
  local tag="${1:-}"
  if [ -n "$tag" ]; then
    [[ "$tag" =~ ^(v[0-9].*|edge|latest)$ ]] \
      || die "Tag inválido: '$tag'. Usá vX.Y.Z, edge o latest."
    bold "Pineando versión: $IMAGE_REPO:$tag"
    set_env_var SANCHOCMO_IMAGE "$IMAGE_REPO:$tag"
  fi
  build_compose_args
  bold "Bajando imágenes ($COMPOSE $COMPOSE_ARGS pull)"
  pull_images
  bold "Aplicando ($COMPOSE $COMPOSE_ARGS up -d)"
  # shellcheck disable=SC2086
  $COMPOSE $COMPOSE_ARGS up -d
  announce_ready
}

# ---------------------------------------------------------------------------
# logs / status — todos los overlays para abarcar cualquier servicio corriendo.
# ---------------------------------------------------------------------------
cmd_logs() {
  require_env; detect_compose; build_compose_args
  local svc="${1:-sanchocmo}"
  # shellcheck disable=SC2086
  exec $COMPOSE $COMPOSE_ARGS logs -f "$svc"
}

cmd_status() {
  require_env; detect_compose; build_compose_args
  # shellcheck disable=SC2086
  $COMPOSE $COMPOSE_ARGS ps
}

# ---------------------------------------------------------------------------
# destroy — down -v. BORRA los datos. Exige confirmación escrita.
# ---------------------------------------------------------------------------
cmd_destroy() {
  require_env; detect_compose; build_compose_args
  bold "⚠ Esto va a BORRAR los datos (volúmenes) del stack:"
  # shellcheck disable=SC2086
  $COMPOSE $COMPOSE_ARGS config --volumes 2>/dev/null | sed 's/^/    - /' || true
  echo ""
  printf '  Escribí "destroy" para confirmar (cualquier otra cosa aborta): '
  local ans; read -r ans </dev/tty || true
  [ "$ans" = "destroy" ] || { echo "  Abortado — no se borró nada."; exit 0; }
  bold "Borrando ($COMPOSE $COMPOSE_ARGS down -v --remove-orphans)"
  # shellcheck disable=SC2086
  $COMPOSE $COMPOSE_ARGS down -v --remove-orphans
  echo "  ✓ Stack y datos eliminados."
}

# ---------------------------------------------------------------------------
# run — el arranque más simple. Sin .env: wizard en modo QUICK + up. Con .env:
# equivale a `up`. En ambos casos abre el navegador en la URL de acceso.
# ---------------------------------------------------------------------------
cmd_run() {
  # Forzar quick para el wizard (si corre) sin pisar un WIZARD_MODE explícito.
  export WIZARD_MODE="${WIZARD_MODE:-quick}"
  cmd_install "$@"
  open_browser
}

# reconfigure — re-corre el wizard (regenera config, conserva datos). Acepta
# --quick / --advanced (y demás flags de install) y los reenvía.
cmd_reconfigure() { cmd_install --force --no-up "$@"; }

# ---------------------------------------------------------------------------
# Dispatch.
# ---------------------------------------------------------------------------
cmd="${1:-help}"; shift || true
case "$cmd" in
  run)                cmd_run "$@" ;;
  install)            cmd_install "$@" ;;
  up|start)           cmd_up ;;
  down|stop)          cmd_down ;;
  restart)            cmd_restart ;;
  update|upgrade)     cmd_update "$@" ;;
  logs)               cmd_logs "$@" ;;
  status|ps)          cmd_status ;;
  destroy)            cmd_destroy ;;
  reconfigure)        cmd_reconfigure "$@" ;;
  link)               cmd_link "$@" ;;
  help|-h|--help)     usage ;;
  *) die "Comando desconocido: $cmd  (probá: ./sancho help)" ;;
esac
