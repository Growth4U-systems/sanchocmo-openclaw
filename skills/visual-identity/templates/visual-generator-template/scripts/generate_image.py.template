def get_next_sequence_number(output_dir='projects'):
    """
    Get next sequence number for image naming.
    Looks for existing images with pattern: YYYYMMDD_NNN_*.png
    Returns next available number.
    """
    date_prefix = datetime.now().strftime('%Y%m%d')
    pattern = f"{output_dir}/*/{date_prefix}_*_*.png"
    existing = glob.glob(pattern)

    if not existing:
        return 1

    # Extract sequence numbers
    numbers = []
    for filepath in existing:
        filename = Path(filepath).stem
        parts = filename.split('_')
        if len(parts) >= 2 and parts[1].isdigit():
            numbers.append(int(parts[1]))

    return max(numbers) + 1 if numbers else 1

def load_guidelines(skill_path):
    """
    Load the 3-layer guideline system from references/

    Returns:
        dict with 'world', 'mapping', 'style' keys
    """
    refs_path = skill_path / 'references'

    def read_md(filepath):
        if filepath.exists():
            with open(filepath, 'r') as f:
                return f.read()
        return None

    guidelines = {
        'world': read_md(refs_path / 'visual-world.md'),
        'mapping': read_md(refs_path / 'idea-mapping.md'),
        'style': read_md(refs_path / 'visual-style.md')
    }

    # Verify all layers loaded
    if not all(guidelines.values()):
        missing = [k for k, v in guidelines.items() if not v]
        print(f"⚠️  Warning: Missing guideline layers: {missing}")

    return guidelines

