def save_metadata(output_path, prompt, negative_prompt, concept, iteration):
    """
    Save generation metadata for tracking and reproduction.
    """
    metadata = {
        'brand': '{{brand_name}}',
        'prompt': prompt,
        'negative_prompt': negative_prompt,
        'concept': concept,
        'iteration': iteration,
        'timestamp': datetime.now().isoformat(),
        'model': 'nanobanana',
        'guidelines_version': '{{generation_date}}'
    }

    metadata_path = output_path.replace('.png', '_metadata.json')
    with open(metadata_path, 'w') as f:
        json.dump(metadata, f, indent=2)

    return metadata_path

def create_project_folder(content_description, sequence_num):
    """
    Create project folder for this visual request.

    Format: projects/YYYYMMDD_NNN_[content_slug]/
    """
    # Create slug from content description
    slug = content_description.lower()
    slug = ''.join(c if c.isalnum() or c in ' -' else '' for c in slug)
    slug = slug.replace(' ', '_')[:40]  # Max 40 chars

    # Add date and sequence
    date_str = datetime.now().strftime('%Y%m%d')
    folder_name = f"{date_str}_{sequence_num:03d}_{slug}"

    # Create in projects/ directory
    project_path = Path('projects') / folder_name
    project_path.mkdir(parents=True, exist_ok=True)

    # Create brief.md with content description
    brief_path = project_path / 'brief.md'
    with open(brief_path, 'w') as f:
        f.write(f"# Visual #{sequence_num:03d}: {content_description}\n\n")
        f.write(f"Created: {datetime.now().strftime('%Y-%m-%d %H:%M')}\n")
        f.write(f"Brand: {{brand_name}}\n")
        f.write(f"Sequence: #{sequence_num:03d}\n\n")
        f.write("## Selected Concept\n\n[Will be added after user selection]\n")

    return project_path

def main():
    parser = argparse.ArgumentParser(
