    # Prepare concept
    concept = {
        'description': args.concept,
        'objects': [],  # TODO: Parse from concept description
        'composition': ''  # TODO: Extract from concept
    }

    # Prepare user preferences
    user_prefs = {
        'color': args.color,
        'dimensions': (width, height)
    }

    # Get next sequence number
    sequence_num = get_next_sequence_number('projects')

    # Create project folder with sequence
    project_folder = create_project_folder(args.concept, sequence_num)

    # Generate filename: YYYYMMDD_NNN_description_vN.png
    date_str = datetime.now().strftime('%Y%m%d')
    concept_slug = args.concept.lower().replace(' ', '_')[:40]
    concept_slug = ''.join(c if c.isalnum() or c == '_' else '' for c in concept_slug)
    filename = f"{date_str}_{sequence_num:03d}_{concept_slug}_v{args.iteration}.png"
    output_path = str(project_folder / filename)

    # Assemble prompt
    full_prompt, negative_prompt = assemble_prompt(concept, guidelines, user_prefs)

    # Generate image
    result = generate_image_nanobanana(
        prompt=full_prompt,
        negative_prompt=negative_prompt,
        width=width,
        height=height,
        output_path=output_path
    )

    # Save metadata
    if result:
        metadata_path = save_metadata(output_path, full_prompt, negative_prompt, concept, args.iteration, sequence_num)
        print(f"\n✅ Image generated: {output_path}")
        print(f"   Sequence: #{sequence_num:03d}")
        print(f"   Iteration: v{args.iteration}")
        print(f"✅ Metadata saved: {metadata_path}")
        return 0
    else:
        print(f"\n⚠️  Would generate: {output_path}")
        print(f"   Sequence: #{sequence_num:03d}")
        print(f"   Iteration: v{args.iteration}")
        print("   (Nanobanana API not implemented)")
        return 1

if __name__ == "__main__":
