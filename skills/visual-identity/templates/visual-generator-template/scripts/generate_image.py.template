def assemble_prompt(concept, guidelines, user_preferences):
    """
    Assemble complete Nanobanana prompt from:
    - Base prompt (Layer 3 aesthetic)
    - Selected concept (objects from Layer 1)
    - User preferences (color, etc.)

    Args:
        concept: dict with 'objects', 'composition', 'description'
        guidelines: dict with 'world', 'mapping', 'style'
        user_preferences: dict with 'color', 'dimensions', etc.

    Returns:
        (full_prompt, negative_prompt) tuple
    """
    # Extract base prompt from Layer 3
    if guidelines.get('style'):
        base_prompt = extract_base_prompt(guidelines['style'])
        negative_prompt = extract_negative_prompts(guidelines['style'])
    else:
        # Fallback if Layer 3 not loaded
        base_prompt = "{{base_prompt_full}}"
        negative_prompt = "{{negative_prompts_full}}"

    # Add selected concept (objects + composition)
    subject = concept.get('description', '')
    if 'objects' in concept:
        objects_str = ', '.join(concept['objects'])
        subject = f"{objects_str}, {concept.get('composition', '')}"

    full_prompt = f"{base_prompt}, {subject}"

    # Add user preferences
    if user_preferences:
        if user_preferences.get('color'):
            full_prompt += f", {user_preferences['color']} color scheme"

    return full_prompt, negative_prompt

