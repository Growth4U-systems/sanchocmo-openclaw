{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Client Integrations",
  "description": "Per-client API integrations: data sources + system overrides. Stored at brand/{slug}/integrations.json",
  "type": "object",
  "properties": {
    "slug": {
      "type": "string",
      "description": "Client slug (e.g. example, example)"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "dataSources": {
      "type": "object",
      "description": "Client's own data source APIs (GA4, GSC, Meta Ads, CRM, etc.)",
      "additionalProperties": {
        "$ref": "#/definitions/integration"
      }
    },
    "systemOverrides": {
      "type": "object",
      "description": "Client overrides for system-level APIs (Anthropic, OpenAI, etc.)",
      "additionalProperties": {
        "$ref": "#/definitions/integration"
      }
    }
  },
  "required": ["slug", "dataSources"],
  "definitions": {
    "integration": {
      "type": "object",
      "properties": {
        "provider": {
          "type": "string",
          "description": "Human-readable provider name"
        },
        "status": {
          "type": "string",
          "enum": ["not_configured", "pending", "testing", "connected", "error", "expired"],
          "default": "not_configured"
        },
        "config": {
          "type": "object",
          "description": "Non-sensitive configuration (IDs, URLs, scopes)",
          "additionalProperties": true
        },
        "envVars": {
          "type": "array",
          "description": "List of env var names where secrets are stored",
          "items": { "type": "string" }
        },
        "lastTestedAt": {
          "type": "string",
          "format": "date-time"
        },
        "lastError": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "required": ["provider", "status"]
    }
  }
}
