{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Health Score — Lightweight dashboard file",
  "description": "Overwritten weekly. Designed for fast MC dashboard consumption.",
  "type": "object",
  "required": ["slug", "updated_at", "overall", "trend", "by_category"],
  "properties": {
    "slug": { "type": "string" },
    "updated_at": { "type": "string", "format": "date-time" },
    "overall": { "type": "integer", "minimum": 0, "maximum": 100 },
    "trend": { "type": "string", "enum": ["improving", "declining", "stable"] },
    "previous_week": { "type": "integer", "minimum": 0, "maximum": 100 },
    "by_category": {
      "type": "object",
      "properties": {
        "traffic": { "$ref": "#/$defs/categoryScore" },
        "paid": { "$ref": "#/$defs/categoryScore" },
        "funnel": { "$ref": "#/$defs/categoryScore" },
        "seo": { "$ref": "#/$defs/categoryScore" },
        "social": { "$ref": "#/$defs/categoryScore" }
      }
    },
    "active_alerts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "severity": { "type": "string", "enum": ["red", "yellow"] },
          "metric": { "type": "string" },
          "message": { "type": "string" },
          "since": { "type": "string", "format": "date" }
        }
      }
    },
    "pending_recommendations_count": { "type": "integer" },
    "last_weekly_report": { "type": "string", "format": "date" }
  },
  "$defs": {
    "categoryScore": {
      "type": "object",
      "properties": {
        "score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "trend": { "type": "string", "enum": ["up", "down", "flat"] }
      }
    }
  }
}
