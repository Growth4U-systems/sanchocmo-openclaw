# ============================================
# SanchoCMO — Environment Variables
# ============================================
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# Required vars are unmarked. Optional ones are commented out.

# === Distribution / core image (OPTIONAL) ===
# The product runs from a public, versioned image: `docker compose pull && up -d`.
# By default the compose file uses `ghcr.io/growth4u-systems/sanchocmo:latest`.
# Pin a specific release for reproducible upgrades (recommended in production):
#   SANCHOCMO_IMAGE=ghcr.io/growth4u-systems/sanchocmo:vX.Y.Z
# Use :edge for the rolling staging build. Leave unset to track :latest.
# (Building from a clone instead? `docker compose build` tags the local build
# with this same name, so you don't need to set anything.)
# SANCHOCMO_IMAGE=ghcr.io/growth4u-systems/sanchocmo:latest

# === Model Providers (set at least one: Anthropic, OpenAI/Codex, or Fireworks) ===
ANTHROPIC_API_KEY=                    # required, unless ANTHROPIC_AUTH_MODE=subscription (then set ANTHROPIC_OAUTH_TOKEN)
ANTHROPIC_OAUTH_TOKEN=                # Claude subscription (Max/Team) OAuth token — get it with `claude setup-token`; required when ANTHROPIC_AUTH_MODE=subscription
# MINIMAX_API_KEY=                    # MiniMax M2.7 — used by specialist agents for execution tasks
# XAI_API_KEY=                        # xAI Grok models
# OPENROUTER_API_KEY=sk-or-v1-...     # OpenRouter proxy (access to multiple providers)
# FIREWORKS_API_KEY=fw-...            # Fireworks AI open-weight models (OpenAI-compatible)
# FIREWORKS_ACCOUNT_ID=your-account-slug  # Optional: enables daily Fireworks usage tracking via billingUsage
# Optional: override Fireworks GLM 5.2 serverless pricing used when billingUsage
# returns tokens but no explicit dollar cost. Values are USD per 1M tokens.
# FIREWORKS_GLM52_INPUT_PER_MTOK=1.40
# FIREWORKS_GLM52_CACHED_INPUT_PER_MTOK=0.14
# FIREWORKS_GLM52_OUTPUT_PER_MTOK=4.40
# FIREWORKS_PRICING_JSON={"accounts/fireworks/models/glm-5p2":{"input_per_mtok":1.40,"cached_input_per_mtok":0.14,"output_per_mtok":4.40}}
# OPENAI_API_KEY=sk-proj-...          # OpenAI models (Codex agents: Cervantes, Yalc)
# PERPLEXITY_API_KEY=pplx-...         # Perplexity web search
# GEMINI_API_KEY=                     # Google Gemini (image generation, analysis)

# --- Auth mode per provider: api_key (default) or subscription ---
# Controls how the OpenClaw gateway authenticates model inference.
#   api_key (default) → uses ANTHROPIC_API_KEY / OPENAI_API_KEY above. This is
#                       the right choice for most installs.
#   subscription      → Anthropic via Claude CLI OAuth (Max/Team plan); OpenAI
#                       via Codex (ChatGPT) OAuth. Requires logging in on the
#                       host with `claude setup-token` / `openclaw models auth
#                       login`. In subscription mode, do NOT also rely on the
#                       API keys for that provider — the subscription profile
#                       takes over.
# ANTHROPIC_AUTH_MODE=api_key
# OPENAI_AUTH_MODE=api_key

# === Agent runtime (runtime-agnostic Sancho; OpenClaw initial adapter) ===
# Fresh self-hosted installs boot with OpenClaw because it is still the complete
# adapter/fallback while the runtime split is being completed. You can configure
# and switch runtimes later from Mission Control → Settings → Runtime.
#
# Runtime != model provider:
# - providers: Anthropic, OpenAI, Fireworks, OpenRouter, etc.
# - runtimes/harnesses: OpenClaw, Hermes, Codex CLI, Claude Code, or another
#   compatible agent gateway.
#
# SANCHO_RUNTIME is the boot-time default / advanced override. Leave it as
# openclaw for the normal curl installer path. Set hermes/external-http only
# when the matching gateway variables below are configured.
# SANCHO_RUNTIME=openclaw
#
# Hermes v1 can run through the bundled Sancho bridge. The bridge receives
# Mission Control chat requests, calls the Hermes CLI, and posts the result back
# to /api/chat/webhook using the same shared secret.
# SANCHO_RUNTIME=hermes
# INSTALL_HERMES=1
# HERMES_AGENT_REF=main
# SANCHOCMO_MC_PORT=13000
# SANCHOCMO_GATEWAY_PORT=18793
# SANCHOCMO_LEGACY_PORT=18794
# HERMES_BRIDGE_ENABLED=1
# HERMES_BRIDGE_PORT=18791
# HERMES_CHAT_SECRET=                    # Generate with: openssl rand -hex 32
# HERMES_CLI=hermes
# HERMES_CLI_PROVIDER=openrouter
# HERMES_CLI_MODEL=openai/gpt-4o-mini
# HERMES_WORKDIR=/root/.openclaw
#
# Use this instead of the bundled bridge when Hermes already exposes a compatible
# gateway elsewhere. Leave unset when HERMES_BRIDGE_ENABLED=1.
# HERMES_GATEWAY_URL=
#
# Optional advanced overrides.
# HERMES_CONTEXT_PACK_ENABLED=1
# HERMES_RUN_TIMEOUT_MS=900000
# HERMES_CONTEXT_PACK_TIMEOUT_MS=5000
#
# BYO / external runtime. Use this when Sancho should call a compatible gateway
# owned by the self-hosting user, client, or partner. That gateway can be backed
# by Hermes, Codex CLI, Claude Code, or another harness that accepts Sancho's
# HTTP contract.
# SANCHO_RUNTIME=external-http
# SANCHO_EXTERNAL_PROTOCOL=sancho        # sancho (async contract) or mc-bridge (sync /chat bridge)
# SANCHO_EXTERNAL_GATEWAY_URL=https://runtime.customer.example
# SANCHO_EXTERNAL_SECRET=
# SANCHO_EXTERNAL_INBOUND_PATH=/sancho/inbound
# SANCHO_EXTERNAL_HEALTH_PATH=/healthz
#
# Existing Mission Control / Hermes bridge compatibility:
# SANCHO_EXTERNAL_PROTOCOL=mc-bridge
# SANCHO_EXTERNAL_GATEWAY_URL=https://bridge.customer.example
# SANCHO_EXTERNAL_CHAT_PATH=/chat
# SANCHO_EXTERNAL_HEALTH_PATH=/health
# SANCHO_EXTERNAL_AGENT=sancho-coordinator
#
# Legacy alias still accepted for old installs:
# SANCHO_RUNTIME=hermes-external
# HERMES_EXTERNAL_GATEWAY_URL=https://hermes.customer.example

# === Discord Bot (OPTIONAL — OpenClaw: Sancho + specialist agents) ===
# Discord is just one comms channel, like Slack — NOT required. Mission Control
# chat (web → Sancho) is the primary interface. Leave this unset to run without
# Discord; set it to enable the Discord channel + guild bindings.
# DISCORD_BOT_TOKEN=

# === Cervantes (Claude Code — runs outside Docker) ===
CERVANTES_GUILD_ID=                   # Discord guild ID where Cervantes operates (excluded from Sancho bindings)
# CLAUDE_CODE_OAUTH_TOKEN is the Claude-Code-native spelling of the subscription
# token, read by the `claude` binary (the Cervantes Discord bot). You normally do
# NOT set it here: when Discord/Cervantes is configured, the entrypoint derives it
# from ANTHROPIC_OAUTH_TOKEN above. Set it explicitly only to run a Cervantes/
# `claude -p` flow with a DIFFERENT token than the gateway motor.
# CLAUDE_CODE_OAUTH_TOKEN=            # optional override; otherwise derived from ANTHROPIC_OAUTH_TOKEN
DISCORD_WEBHOOK_CERVANTES=            # Webhook URL for #cervantes-admin channel

# === URLs ===
BASE_URL=https://your-domain.com
# MC_BASE_URL is derived automatically: ${BASE_URL}/mc

# === Next.js Mission Control ===
# DATABASE_URL — Postgres connection string powering MI/POV/Polar (and tasks
# once cut over to DB). Two ways to provide it:
#
#   1) Bundled local Postgres (recommended; the wizard sets this up): keep the
#      `local-db` Compose profile active (COMPOSE_PROFILES below) and use the
#      in-network host `postgres`. The container creates the schema at boot.
#      Example value: postgres://sancho:<password>@postgres:5432/sancho
#      (the POSTGRES_PASSWORD below must match the password in that URL.)
#
#   2) External / managed (e.g. Neon): leave the profile empty (no bundled PG)
#      and set the URL to your DB, e.g.
#      postgresql://user:pass@ep-xxx.region.neon.tech/mc
#
# Leave it empty for pure JSON mode — the Drizzle client is lazy and only throws
# if a DB-backed feature is actually used.
#
# DATABASE_DRIVER auto-detects from the host (*.neon.tech -> Neon's HTTP driver,
# anything else -> vanilla Postgres). Set it to `neon` or `postgres` to override.
#
# NOTE: comments here avoid the literal `KEY` + `=` form on purpose — the
# wizard's set_env() matches `^#?\s*KEY=` and would otherwise target a commented
# example instead of the real assignment line below.
DATABASE_URL=postgres://sancho:CHANGE_ME@postgres:5432/sancho
# POSTGRES_PASSWORD=CHANGE_ME
# DATABASE_DRIVER=
# COMPOSE_PROFILES=local-db
# Tasks backend selector:
#   json       — read/write tasks from workspace-sancho/brand/<slug>/projects/*.json (default)
#   db-shadow  — JSON is authoritative, DB shadow-writes happen on the side (rollout-only)
#   db         — the DB is authoritative; DATABASE_URL required
# Migration runbook lives in docs/db-tasks-migration.md (TODO).
# MC_TASKS_BACKEND=json
# MC_TASKS_WORKSPACE matches the value indexed in the tasks table. Default
# "workspace-sancho" aligns with MC_WORKSPACE inside the container.
# MC_TASKS_WORKSPACE=workspace-sancho
# The entrypoint runs a boot preflight that aborts with an actionable message
# when a MUST var/config is missing. Set SKIP_PREFLIGHT=1 to bypass (debugging only).
# SKIP_PREFLIGHT=0
NEXTAUTH_URL=https://your-domain.com
NEXTAUTH_SECRET=                      # Generate with: openssl rand -base64 32
GOOGLE_CLIENT_ID=                      # optional — Google login. Leave EMPTY to disable (a placeholder here breaks login with invalid_client).
GOOGLE_CLIENT_SECRET=                  # optional — pair with GOOGLE_CLIENT_ID
# GOOGLE_OAUTH_CLIENT_ID=             # Backward-compatible alias for GOOGLE_CLIENT_ID
# GOOGLE_OAUTH_CLIENT_SECRET=         # Backward-compatible alias for GOOGLE_CLIENT_SECRET
# MC_ADMIN_TOKEN=                     # Optional dev/admin fallback if config/clients.json is unavailable
# ADMIN_EMAIL_DOMAIN: comma-separated bare domains whose Google accounts are
# admin automatically at login (e.g. "acme.com,acme.io"). Leave empty for no
# implicit domain admin — admins are then only the explicit clients.json
# adminEmails plus the admin token.
# ADMIN_EMAIL_DOMAIN=
# ADMIN_IDENTITY_EMAIL: synthetic email shown for the admin-token session
# (defaults to admin@localhost).
# ADMIN_IDENTITY_EMAIL=
# NEXT_PUBLIC_ENV_LABEL=STAGING       # Shows a badge next to the version in the sidebar (e.g. STAGING, PREVIEW). Leave empty in prod.

# === Internal APIs ===
# Used by Mission Control to read Sancho live status. Generate with: openssl rand -hex 32
SANCHO_INTERNAL_API_TOKEN=

# === Slack (multi-tenant OAuth) ===
# Created at https://api.slack.com/apps → Your App → Basic Information
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
# Must EXACTLY match a Redirect URL registered in the Slack app:
SLACK_REDIRECT_URI=                    # e.g. https://your-domain.com/api/integrations/slack/oauth/callback
# Required for /api/integrations/slack/interactivity (verifies HMAC of Slack-signed requests).
# api.slack.com/apps → Your App → Basic Information → "Signing Secret"
SLACK_SIGNING_SECRET=
# Optional: override default bot scopes (comma-separated). Default covers OAuth installs
# for posting, reading public/private channels where the bot is added, and uploading files.
# SLACK_BOT_SCOPES=

# === Token Encryption ===
# Used to encrypt third-party OAuth tokens (Slack bot tokens, etc.) at rest.
# Generate with: openssl rand -hex 32   (produces 64 hex chars = 32 bytes / 256 bits)
# Rotating this key invalidates all stored tokens. Do NOT commit.
ENCRYPTION_KEY=

# === Cloudflare R2 (image uploads for Mission Control) ===
# CLOUDFLARE_ACCOUNT_ID=
# R2_UPLOAD_IMAGE_ACCESS_KEY_ID=
# R2_UPLOAD_IMAGE_SECRET_ACCESS_KEY=
# R2_UPLOAD_IMAGE_BUCKET_NAME=
# R2_PUBLIC_URL=

# === Payments (Polar) ===
# POLAR_ACCESS_TOKEN=
# POLAR_SERVER=sandbox                # "sandbox" or "production"
# POLAR_WEBHOOK_SECRET=

# === Search & Scraping (used by Sancho skills) ===
# SERPER_API_KEY=                     # Serper.dev Google Search
# FIRECRAWL_API_KEY=                  # Firecrawl web scraping
# BRAVE_API_KEY=                      # Brave Search
# EXA_API_KEY=                        # Exa neural search
# SCRAPECREATORS_API_KEY=             # ScrapeCrators (Reddit, TikTok, Instagram)
# APIFY_API_KEY=                      # Apify web scraping

# === Social & Marketing ===
# META_ADS_TOKEN=                     # Meta Ads API
# METRICOOL_API_KEY=                  # Metricool analytics
# METRICOOL_USER_TOKEN=
# METRICOOL_USER_ID=
# METRICOOL_BLOG_ID=
# APOLLO_API_KEY=                     # Apollo.io prospecting

# === Google Integrations ===
# GOOGLE_REFRESH_TOKEN=               # For GSC and GA4 queries
# PAGESPEED_API_KEY=                  # Google PageSpeed Insights

# === External Services ===
# NOTION_API_KEY=
# SLACK_BOT_TOKEN=                         # Fallback para Slack si no hay token dedicado del reporte
# LLM_USAGE_SLACK_CHANNEL=C0AHWST8Y5C       # Canal Slack para el reporte diario de consumo LLM total
# LLM_USAGE_SLACK_REPORT_HOUR=9             # Hora local para enviar el reporte diario
# LLM_USAGE_SLACK_REPORT_MINUTE=0
# LLM_USAGE_SLACK_REPORT_TIMEZONE=Europe/Madrid
# LLM_USAGE_SLACK_REPORT_ENABLED=1
# LLM_USAGE_SLACK_REQUIRE_BILLING=0         # Poner 1 para bloquear si el billing del proveedor no está disponible
# LLM_USAGE_SLACK_BOT_TOKEN=                # Token dedicado del reporte (opcional si SLACK_BOT_TOKEN es SanchoCMO)
# LLM_USAGE_SLACK_EXPECTED_BOT=SanchoCMO    # auth.test debe devolver este usuario/bot; evita publicar desde ideasbot por error.
# LLM_USAGE_SLACK_ALLOW_DEFAULT_TOKEN=1     # Usa SLACK_BOT_TOKEN como fallback si falta el token dedicado.
# LLM_USAGE_USD_TO_EUR=0.92                 # Fireworks factura en USD; Sancho muestra el tracker en EUR con este tipo.
# FAL_API_KEY=                        # Image generation (Fal.ai)
# WAVESPEED_API_KEY=
# INSTANTLY_API_KEY=                  # Email outreach

# === YALC / GTM-OS (Outreach engine; opt-in overlay docker-compose.yalc.yml) ===
# Local dev outside Docker: http://localhost:3847
# Docker/staging with docker-compose.yalc.yml: http://yalc:3847
# Docker when YALC runs on the host: http://host.docker.internal:3847
# YALC_BASE_URL=http://localhost:3847
# YALC_API_TOKEN=                     # Same value as GTM_OS_API_TOKEN in YALC if bearer auth is enabled
# YALC_IMAGE: pin the public image tag. Defaults to ghcr.io/growth4u-systems/yalc:edge
# YALC_IMAGE=ghcr.io/growth4u-systems/yalc:edge
# YALC_DATA_VOLUME=yalc_data          # Or an absolute host path, e.g. /mnt/data/yalc-gtm-os
# YALC_PORT=3847
# GROWTH4U_YALC_BASE_URL=http://localhost:3847
# GROWTH4U_YALC_API_TOKEN=
# YALC_CALLBACK_SECRET=               # Shared secret for YALC async-job callbacks → POST /api/yalc/job-callback (x-yalc-secret header). When set, callbacks without a matching header are rejected; when unset, allowed (dev only).
# The async-job callbackUrl is built from SANCHO_BASE_URL (else BASE_URL, default http://localhost:3000) + /api/yalc/job-callback.
# SANCHO_BASE_URL=                    # Sancho's own externally reachable base URL, used by yalc-client to tell YALC where to POST job results.
# SANCHO_REPLY_WEBHOOK_URL=http://sanchocmo:3000/api/yalc/replies
# SANCHO_REPLY_WEBHOOK_TOKEN=          # Bearer token accepted by Sancho's POST /api/yalc/replies and sent by YALC. Set in prod.

# === Data snapshots (defaults to /mnt/data/snapshots) ===
# SNAPSHOT_DATA_DIR=/mnt/data/snapshots

# === Path overrides (defaults to ~/.openclaw) ===
# OPENCLAW_HOME=~/.openclaw

# === Tailscale (only for local dev, not needed on VPS) ===
# TS_AUTHKEY=tskey-auth-...

# === Open Design (agentic editor) — OPTIONAL ===
# Open Design is an OPT-IN overlay. The base stack boots without it. Enable it by
# layering the overlay on top of the base compose file:
#   docker compose -f docker-compose.yml -f docker-compose.od.yml up -d
# (G4U deploys keep it on by default; set ENABLE_OD_SERVICE=0 to skip it.)
# The `open-design` service runs the daemon + web app on port 7456. MC talks to
# it server-to-server via the compose network, and the user's browser loads the
# web app (iframe / new tab) from the public URL.
#
# OD_DAEMON_URL: server-side, defaults to http://open-design:7456 (compose DNS).
# OD_WEB_URL:    browser-side, must be set to a public URL the user can reach.
#                Typically a dedicated subdomain proxied to 127.0.0.1:7456.
# OD_ALLOWED_ORIGINS: comma-separated origins the OD daemon accepts requests
#                from (same as OD_WEB_URL, plus any embedding origin if you
#                want MC to iframe it from a different host).
# OD_API_TOKEN:  REQUIRED for the fork's :edge image (Phase 5 safety floor).
#                The daemon refuses to bind to 0.0.0.0 without it, and every
#                /api/* request must carry `Authorization: Bearer <token>`.
#                The setup-open-design.sh script generates one and wires it
#                into both .env and the nginx vhost (which injects the
#                bearer for browser traffic so the OD web app keeps working).
#                Generate manually with: openssl rand -hex 32
# OPEN_DESIGN_IMAGE: pin the image tag. Defaults to ghcr.io/growth4u-systems/od:edge
#                (the Growth4U fork's rolling `main` build). Use :sha-<short> for a
#                specific commit, or :vX.Y.Z (e.g. on prod) for a pinned release.
# OPEN_DESIGN_MEM_LIMIT: container memory limit (defaults to 384m).
# OD_DAEMON_URL=http://open-design:7456
# OD_WEB_URL=https://od.staging.your-domain.com
# OD_ALLOWED_ORIGINS=https://od.staging.your-domain.com
# OD_API_TOKEN=                       # 64 hex chars from `openssl rand -hex 32`
# OPEN_DESIGN_IMAGE=ghcr.io/growth4u-systems/od:edge
# OPEN_DESIGN_MEM_LIMIT=384m
