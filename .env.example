# === Model Providers (at least one required) ===
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-proj-...
# OPENROUTER_API_KEY=sk-or-v1-...
# PERPLEXITY_API_KEY=pplx-...

# === Discord Bot ===
DISCORD_BOT_TOKEN=your-bot-token
DISCORD_CLIENT_ID=your-bot-client-id
CERVANTES_GUILD_ID=your-infra-guild-id

# === Tailscale (only for local dev, not needed on VPS) ===
# TS_AUTHKEY=tskey-auth-...
# BASE_URL=https://your-host.ts.net

# === Path overrides (defaults to ~/.openclaw) ===
# OPENCLAW_HOME=~/.openclaw
# MC_BASE_URL=https://your-domain.com/mc
