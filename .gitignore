discord/command-deploy-cache.json

# Plugins runtime
plugins/installs.json

# Tailscale device certs (secrets — NEVER commit)
*.taild*.ts.net.crt
*.taild*.ts.net.key

# Refactor-side ephemeral / deploy markers
OD_VERSION.txt
PLAN-chat-progress-streaming.md
openclaw.json.last-good

# SAN-445: deploy checkout-collision backups (untracked paths that would block
# `git checkout <ref>` on the VPS are moved here before checkout; kept for
# recovery, ignored so they never themselves block a future checkout).
.deploy-collision-backups/

# ACP / Codex local config (per-machine)
acpx/codex-home/

# Workspace framework runtime (instance-specific)
workspace-sancho/.clawhub/lock.json
workspace-sancho/costs-daily.json
workspace-sancho/costs-global.json
workspace-sancho/cron/jobs.json
workspace-sancho/cron/jobs.json.pre-*
workspace-sancho/cron/jobs.json.bak

# Generated env backups (timestamped)
.env.bak-*
.env.local.bak-*

# Python bytecode (scripts/upsert-env.py and its tests)
__pycache__/
*.py[cod]

# === Fase 0 / public-repo purge guards (SAN-340) ===
# Keep per-instance data & data-as-code from being re-tracked after the purge.
.archived/
workspace-sancho/_system/recurring-tasks/
# Dead legacy dashboard (only referenced by legacy-mc-server.js/legacy-mc-work.js,
# neither launched at boot). NOTE: workspace-sancho/mission-control.html is KEPT
# and tracked — it's still served by mc-server.js:18790 (Strangler-Fig fallback).
workspace-sancho/legacy-mission-control.html
# Legacy data-as-code (SAN-109 retirement targets)
workspace-sancho/legacy-*.js
workspace-sancho/mc-data.js
# Backup copies of scripts
workspace-sancho/scripts/*.backup*
# Any TLS cert / private key must never be tracked
*.key
*.crt
*.ts.net.crt

# === Planning docs — keep LOCAL only, never in the public repo (SAN-340) ===
docs/plans/
