# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# worktrees
.worktrees/

# dependencies
/node_modules
node_modules/
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Log del último install/up/update que escribe el checklist del CLI sancho.
.sancho/

# local env files + ALL .env variants (backups, pre-rotation snapshots, etc.)
# Operators create ad-hoc .env backups during key rotations with arbitrary
# suffixes (.env.bak-*, .env.backup-*, .env.pre-*, ...). Catch them all and
# only allow the committed templates/examples back in. See SAN-233.
.env
.env.*
!.env.example
!.env.template

# Runtime/agent files that frequently capture secrets — never track. Found on
# prod as untracked-but-committable holding live secrets (SAN-233):
#  - Codex shell-history snapshots (env + commands)
#  - timestamped *.old.<date>/ backup dirs and *.bak-<ts> files
**/shell_snapshots/
*.old.[0-9]*/
*.bak-*
*.bak.[0-9]*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

